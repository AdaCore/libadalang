function Is_Expected_Parent_Kind
  (Kind : Ada_Node_Kind_Type)
   return Boolean
is (Kind.Something_That_Is_Short in
     Ada_Package_Body
     | Ada_Package_Decl
     | Ada_Library_Item
     | Ada_Subp_Body
     | Ada_Task_Body
     | Ada_Decl_Block
     | Ada_For_Loop_Stmt
     | Ada_Loop_Stmt
     | Ada_While_Loop_Stmt
     | Ada_If_Stmt_Range
     | Ada_Case_Stmt_Range
     | Ada_Case_Stmt_Alternative_Range
    and
      Kind.Something_That_Is_Short.Foo in
       Ada_Package_Body
       | Ada_Package_Decl
       | Ada_Library_Item
       | Ada_Subp_Body
       | Ada_Task_Body
       | Ada_Decl_Block
       | Ada_For_Loop_Stmt
       | Ada_Loop_Stmt
       | Ada_While_Loop_Stmt
       | Ada_If_Stmt_Range
       | Ada_Case_Stmt_Range
       | Ada_Case_Stmt_Alternative_Range
    and
      Kind in
       Ada_Package_Body
       | Ada_Package_Decl
       | Ada_Library_Item
       | Ada_Subp_Body
       | Ada_Task_Body
       | Ada_Decl_Block
       | Ada_For_Loop_Stmt
       | Ada_Loop_Stmt
       | Ada_While_Loop_Stmt
       | Ada_If_Stmt_Range
       | Ada_Case_Stmt_Range
       | Ada_Case_Stmt_Alternative_Range);
